NODE_ENV=development
PORT=3000

DATABASE_URL="mysql://root@localhost:3306/qurbankit_db"
DATABASE_USER="root"
DATABASE_PASSWORD=""
DATABASE_NAME="qurbankit_db"
DATABASE_HOST="localhost"
DATABASE_PORT=3306

# Session
SESSION_LIFETIME=15

# S3 Compatible Storage Configuration (MinIO, Wasabi, DigitalOcean Spaces, etc.)
# ============================================================================
# Endpoint URL of your S3 compatible service
# Examples:
# - MinIO: http://localhost:9000 or https://minio.example.com
# - Wasabi: https://s3.wasabisys.com
# - DigitalOcean Spaces: https://nyc3.digitaloceanspaces.com
# - AWS S3: https://s3.amazonaws.com
S3_ENDPOINT=http://localhost:9000

# AWS/S3 Region
# For S3 compatible services, use the region closest to you or as specified by your provider
# Default: us-east-1
S3_REGION=us-east-1

# S3 Access Key ID
# Your S3 access key or MinIO access key
S3_ACCESS_KEY_ID=minioadmin

# S3 Secret Access Key
# Your S3 secret key or MinIO secret key
S3_SECRET_ACCESS_KEY=minioadmin

# S3 Bucket Name
# The bucket/container name where files will be stored
S3_BUCKET=qurbankit-uploads

# Force Path Style (true for S3 compatible services like MinIO, false for AWS S3)
# Set to "true" for MinIO, Wasabi, and most S3 compatible services
# Set to "false" for AWS S3
S3_FORCE_PATH_STYLE=true